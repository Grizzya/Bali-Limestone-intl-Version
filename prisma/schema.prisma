generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql" 
  url      = env("DATABASE_URL")
}

// --- TABEL ADMIN ---
model Admin {
  id        String         @id @default(cuid())
  username  String         @unique
  email     String         @unique
  password  String         
  nama      String         
  role      String         @default("ADMIN") 
  isActive  Boolean        @default(true)
  logs      LogAktivitas[] 
  createdAt DateTime       @default(now())
}

// --- TABEL LOG AKTIVITAS ---
model LogAktivitas {
  id        String   @id @default(cuid())
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  aksi      String   
  detail    String   
  createdAt DateTime @default(now())
}

// --- TABEL KATEGORI ---
model Kategori {
  id        String   @id @default(cuid())
  nama      String  
  namaId    String?  
  produk    Produk[] 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- TABEL PRODUK ---
model Produk {
  id          String   @id @default(cuid())
  nama        String   
  namaId      String?  
  deskripsi   String   @db.Text 
  deskripsiId String?  @db.Text 
  gambar      String?  
  kategoriId  String
  kategori    Kategori @relation(fields: [kategoriId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Artikel {
  id               String   @id @default(cuid())
  slug             String   @unique
  judul            String
  judulId          String?
  konten           String   @db.Text
  kontenId         String?  @db.Text
  gambar           String?

  focusKeywordEn   String?
  focusKeywordId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- TABEL JASA ---
model Jasa {
  id              String   @id
  nama            String
  namaId          String?
  deskripsi       String   @db.Text
  deskripsiId     String?  @db.Text
  deskripsiLengkap   String?  @db.Text
  deskripsiLengkapId String?  @db.Text
  gambar          String?
  gambar2         String?
  gambar3         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// --- TABEL TESTIMONI ---
model Testimoni {
  id        String   @id @default(cuid())
  nama      String   
  peran     String   // Kolom Bahasa Inggris (Default)
  peranId   String?  // 
  pesan     String   @db.Text // Kolom Bahasa Inggris (Default)
  pesanId   String?  @db.Text // 
  rating    Int      
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}